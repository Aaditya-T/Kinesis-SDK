# =============================================================================
# xrpl-gaming-server — required environment variables
# Copy to `.env` and fill in real values before running.
# =============================================================================

# Port the HTTP server binds to. Defaults to 3000.
PORT=3000

# Shared secret required in the `x-api-key` header on every request.
# Generate with: openssl rand -hex 32
# Must be at least 16 characters.
SERVER_API_KEY=change-me-to-a-long-random-string

# XRPL JSON-RPC / WebSocket node URL.
#   Testnet:  wss://s.altnet.rippletest.net:51233
#   Devnet:   wss://s.devnet.rippletest.net:51233
#   Mainnet:  wss://xrplcluster.com
XRPL_NODE_URL=wss://s.altnet.rippletest.net:51233

# Family seed (s...) for the issuer wallet that mints + modifies NFTs.
# Generate a testnet wallet at https://xrpl.org/xrp-testnet-faucet.html
# WARNING: this seed controls all minted NFTs. Treat it like a private key.
XRPL_ISSUER_SEED=sEd...

# Pinata JWT (preferred). Create at https://app.pinata.cloud/developers/api-keys
# Alternatively, fork the CLI to use { apiKey, secretKey } per the
# @workspace/xrpl-gaming-ipfs-pinata README.
PINATA_JWT=eyJhbGciOi...

# Postgres connection string. The PostgresAdapter auto-creates its single
# `xrpl_gaming_nfts` table and indexes on first start.
DATABASE_URL=postgres://xrpl:xrpl@localhost:5432/xrpl_gaming

# Optional: pino log level (trace|debug|info|warn|error|fatal). Defaults to info.
LOG_LEVEL=info

# Optional: when set to "production" disables pino-pretty colored output.
NODE_ENV=development
