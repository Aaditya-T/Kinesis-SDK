{
  "name": "xrpl-gaming-server",
  "version": "0.2.0",
  "description": "Self-hostable HTTP/REST server that exposes the Kinesis XRPL DynamicNFT Gaming SDK over a JSON API. Designed for game studios on non-JavaScript platforms (Unity, Unreal, native mobile) that cannot import the Node.js SDK directly.",
  "keywords": [
    "xrpl",
    "nft",
    "dynamic-nft",
    "gaming",
    "rest",
    "express",
    "kinesis",
    "sdk",
    "server"
  ],
  "author": "Aaditya T",
  "license": "MIT",
  "homepage": "https://github.com/Aaditya-T/Kinesis-SDK/tree/main/lib/xrpl-gaming-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aaditya-T/Kinesis-SDK.git",
    "directory": "lib/xrpl-gaming-server"
  },
  "bugs": {
    "url": "https://github.com/Aaditya-T/Kinesis-SDK/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.17"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "workspace": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "xrpl-gaming-server": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docker-compose.example.yml",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./build.mjs",
    "prepack": "tsc -p tsconfig.json && node ./build.mjs",
    "start": "node --enable-source-maps ./dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "express": "^5",
    "pino": "^9",
    "pino-http": "^10",
    "xrpl-gaming-core": "workspace:*",
    "xrpl-gaming-db-postgres": "workspace:*",
    "xrpl-gaming-ipfs-pinata": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
