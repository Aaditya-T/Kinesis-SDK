{
  "name": "xrpl-gaming-core",
  "version": "0.2.0",
  "description": "Core of the Kinesis XRPL DynamicNFT Gaming SDK. Provides the XRPLGamingSDK class plus pluggable IDBAdapter and IIPFSAdapter interfaces for minting, updating, transferring, burning and querying mutable game NFTs on the XRP Ledger.",
  "keywords": [
    "xrpl",
    "xrp",
    "nft",
    "dynamic-nft",
    "nftokenmodify",
    "gaming",
    "kinesis",
    "sdk"
  ],
  "author": "Aaditya T",
  "license": "MIT",
  "homepage": "https://github.com/Aaditya-T/Kinesis-SDK/tree/main/lib/xrpl-gaming-core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aaditya-T/Kinesis-SDK.git",
    "directory": "lib/xrpl-gaming-core"
  },
  "bugs": {
    "url": "https://github.com/Aaditya-T/Kinesis-SDK/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.17"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "workspace": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "xrpl": "^4.0.0"
  }
}
